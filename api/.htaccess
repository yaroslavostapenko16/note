# API Directory Configuration
# Root .htaccess already handles routing to this directory

# Disable directory listing
<FilesMatch "^$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow api.php
<Files api.php>
    Allow from all
</Files>

# Protect config files
<FilesMatch "^(config|database|test)\.php$">
    Deny from all
</FilesMatch>

# Disable rewriting - root .htaccess handles it
<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>


